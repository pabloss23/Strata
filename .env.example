# Copia a .env y rellena. NUNCA subas .env al repositorio.

# IA GRATUITA para los briefings de Founders (lado servidor, api/briefing.ts).
# Consigue una clave gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: modelo (por defecto gemini-2.0-flash, dentro del nivel gratuito)
GEMINI_MODEL=gemini-2.0-flash

# (Opcional) API de Anthropic, si prefieres Claude en vez de Gemini.
ANTHROPIC_API_KEY=

# Supabase (opcional, persistencia v2)
SUPABASE_URL=
SUPABASE_ANON_KEY=
